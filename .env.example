# ── AI engine ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...            # set on Railway, never commit
ARGUS_MODEL=claude-opus-4-8             # audit reasoning model (sonnet-5 for cheaper jobs)

# ── x402 payment (OKX facilitator, X Layer) ──────────────────────────────────
X402_NETWORK=eip155:196                 # X Layer mainnet (eip155:1952 = testnet)
PAY_TO_ADDRESS=0xYourReceivingWallet    # wallet that receives audit fees
ARGUS_PRICE_USD=$200                    # price per full attack simulation (buyer pays this in USD₮0)
TRIAGE_PRICE_USD=$15                    # price per quick-triage scan (POST /triage)
OKX_API_KEY=                            # from OKX Developer Portal
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# ── Job caps (protect margin — the "Frank trap") ─────────────────────────────
MAX_TOOL_ITERATIONS=60                  # hard ceiling on agentic loop turns per full audit
MAX_WALLCLOCK_SEC=1200                  # 20 min max per full audit before it wraps up
TRIAGE_MAX_TOOL_ITERATIONS=10           # hard ceiling for the cheap triage tier
TRIAGE_MAX_WALLCLOCK_SEC=180            # 3 min max for triage before it wraps up
MAX_OUTPUT_TOKENS_PER_TURN=8000
MAX_INPUT_SCOPE_CHARS=200000            # reject pasted-source scopes larger than this

# ── Runtime ──────────────────────────────────────────────────────────────────
PORT=3000
WORKSPACE_ROOT=./workspaces             # per-job sandboxes (on a Railway volume in prod)
JOBS_FILE=./jobs.json                   # simple persistence; swap for a DB later
